# Copy to render.yaml only if you upgrade to a paid Render plan (Starter+).
# Free tier does NOT support disks — Blueprint deploy will fail with disk: section.
services:
  - type: web
    name: elementary-learning-hub
    runtime: node
    plan: starter
    buildCommand: npm run install:all && npm run build
    startCommand: npm run start
    envVars:
      - key: NODE_ENV
        value: production
      - key: JWT_SECRET
        generateValue: true
      - key: DATA_DIR
        value: /var/data
    disk:
      name: learning-hub-data
      mountPath: /var/data
      sizeGB: 1
