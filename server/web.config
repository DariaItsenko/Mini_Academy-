<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Tell IIS to hand all requests to iisnode, which runs index.js -->
    <handlers>
      <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>

        <!-- Do not interfere with the iisnode debugger endpoint -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^index.js\/debug[\/]?" />
        </rule>

        <!-- Serve actual files on disk (static assets in public/, etc.) directly -->
        <rule name="StaticContent" stopProcessing="true">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Route everything else through index.js (API + SPA fallback) -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="index.js" />
        </rule>

      </rules>
    </rewrite>

    <!-- Allow the iisnode log directory to be created -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Pass Express errors through instead of IIS replacing them -->
    <httpErrors existingResponse="PassThrough" />

    <!-- Reload the app if web.config changes -->
    <iisnode watchedFiles="web.config;*.js" />

  </system.webServer>
</configuration>
